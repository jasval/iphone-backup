# Copy this file to .env and fill in your values.

# Path on NAS where backups will be stored
BACKUP_PATH=/volume1/iphone-backups

# Cron schedule – default 2am daily. Use https://crontab.guru to customise.
BACKUP_CRON=0 2 * * *

# Tailscale IPs of iPhones (comma-separated). Leave blank for LAN-only discovery.
# Find in Tailscale admin console or: tailscale status
IPHONE_TAILSCALE_IPS=

# Timezone (used for cron)
TZ=Europe/London
